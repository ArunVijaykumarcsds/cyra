# CYRA Environment Configuration
# Copy this file to .env and fill in values

# App
VITE_APP_NAME=CYRA
VITE_APP_VERSION=1.0.0

# NASA APIs (optional - for future live data integration)
# VITE_NASA_API_KEY=your_nasa_api_key_here
# VITE_NASA_APOD_URL=https://api.nasa.gov/planetary/apod

# Space APIs (optional)
# VITE_SPACE_NEWS_API=https://api.spaceflightnewsapi.net/v4

# Analytics (optional)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Feature flags
VITE_ENABLE_DEBUG=false
VITE_ENABLE_PERF_MONITOR=false
